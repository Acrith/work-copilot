# Work Copilot environment configuration template.
#
# Copy this file to `.env` at the repository root and fill in real values
# locally. The `.env` file is git-ignored; this `.env.example` file is
# tracked and must NEVER contain real secrets, tenant identifiers, app
# IDs, certificate thumbprints, paths, or passwords.
#
# All settings here are commented out so that an unmodified copy keeps
# Work Copilot in its safe defaults (mock Exchange inspector, no real
# external calls).


# -----------------------------------------------------------------------------
# Provider API keys
# -----------------------------------------------------------------------------
# Used by providers/factory.py to talk to the model providers.
# Set whichever provider(s) you actually use.

# GEMINI_API_KEY="your-gemini-api-key"
# OPENAI_API_KEY="your-openai-api-key"


# -----------------------------------------------------------------------------
# Provider/model selection (optional)
# -----------------------------------------------------------------------------
# Override the default provider and model without passing CLI flags.

# WORK_COPILOT_PROVIDER="gemini"
# WORK_COPILOT_MODEL="gemini-2.5-flash"


# -----------------------------------------------------------------------------
# ServiceDesk Plus connector (optional)
# -----------------------------------------------------------------------------
# Required only when working with the `/sdp` workflows against a real
# ServiceDesk Plus instance. Leave disabled to keep the connector off.

# WORK_COPILOT_ENABLE_SERVICEDESKPLUS="false"
# SDP_DEPLOYMENT="onprem"
# SDP_BASE_URL="https://servicedesk.example.com"
# SDP_PORTAL="example"
# SDP_AUTHTOKEN=""
# SDP_OAUTH_ACCESS_TOKEN=""
# SDP_DEFAULT_REQUEST_FILTER=""


# -----------------------------------------------------------------------------
# Exchange mailbox inspector (read-only, opt-in)
# -----------------------------------------------------------------------------
# The Exchange mailbox inspector defaults to the mock backend with no real
# external calls. Real Exchange Online inspection is opt-in only and
# requires BOTH of the gating variables below to be set as shown.
#
# Even when enabled, the inspector is read-only: no mailbox content,
# attachments, permission changes, archive enablement, or retention
# changes. See docs/exchange_real_inspector_smoke.md for details.

# Backend selection. Allowed values: mock | disabled | exchange_online_powershell
# WORK_COPILOT_EXCHANGE_INSPECTOR_BACKEND="mock"

# Double opt-in. Must be "true" for the real backend to be allowed.
# WORK_COPILOT_ALLOW_REAL_EXCHANGE_INSPECTOR="false"

# PowerShell executable used to invoke Exchange Online PowerShell.
# On WSL/Linux this is typically `pwsh` (PowerShell 7).
# WORK_COPILOT_EXCHANGE_POWERSHELL_EXECUTABLE="pwsh"

# Timeout in seconds for any single Exchange PowerShell command.
# WORK_COPILOT_EXCHANGE_POWERSHELL_TIMEOUT_SECONDS="60"


# -----------------------------------------------------------------------------
# Exchange PowerShell authentication (opt-in)
# -----------------------------------------------------------------------------
# Required only when the real backend is enabled.
# Allowed auth modes: disabled | app_certificate_thumbprint | app_certificate_file
#
# On WSL/Linux prefer `app_certificate_file` because the Windows
# certificate store is not available there.
#
# Auth values must never appear in inspector JSON, run logs, stdout,
# stderr, approval previews, or ServiceDesk notes.

# WORK_COPILOT_EXCHANGE_AUTH_MODE="disabled"
# WORK_COPILOT_EXCHANGE_APP_ID="<azure-ad-app-client-id>"
# WORK_COPILOT_EXCHANGE_ORGANIZATION="<tenant>.onmicrosoft.com"

# --- app_certificate_thumbprint mode (Windows hosts with cert store) ---
# WORK_COPILOT_EXCHANGE_CERTIFICATE_THUMBPRINT="<certificate-thumbprint>"

# --- app_certificate_file mode (preferred on WSL/Linux) ---
# WORK_COPILOT_EXCHANGE_CERTIFICATE_PATH="/absolute/path/to/cert.pfx"
# Name of an additional environment variable that holds the certificate
# password. The PowerShell script reads the password from the variable named here.
#
# Recommended: export the actual password in your shell or secret manager,
# not in `.env`.
#
# Example shell export:
# export WORK_COPILOT_EXCHANGE_CERTIFICATE_PASSWORD="<certificate-password>"
#
# WORK_COPILOT_EXCHANGE_CERTIFICATE_PASSWORD_ENV_VAR="WORK_COPILOT_EXCHANGE_CERTIFICATE_PASSWORD"

# -----------------------------------------------------------------------------  
# Active Directory inspector (read-only, opt-in)
# -----------------------------------------------------------------------------
# Defaults to mock. Real on-prem AD inspection is opt-in only and requires both:
# WORK_COPILOT_AD_INSPECTOR_BACKEND=active_directory_powershell
# WORK_COPILOT_ALLOW_REAL_AD_INSPECTOR=true

# Allowed values: mock | disabled | active_directory_powershell
# WORK_COPILOT_AD_INSPECTOR_BACKEND="mock"

# Double opt-in. Must be "true" for the real AD backend.
# WORK_COPILOT_ALLOW_REAL_AD_INSPECTOR="false"

# Windows PowerShell executable used for the ActiveDirectory module.
# From WSL this may be powershell.exe or an absolute Windows path.
# WORK_COPILOT_AD_POWERSHELL_EXECUTABLE="powershell.exe"

# Timeout in seconds for any single AD PowerShell command.
# WORK_COPILOT_AD_POWERSHELL_TIMEOUT_SECONDS="60"
